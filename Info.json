{
  "name": "Polyscript",
  "identifier": "app.polyscript.iina-plugin",
  "version": "1.0.6",
  "ghRepo": "SammoMichael/polyplugin-release",
  "ghVersion": 7,
  "description": "Dual subtitles with hover dictionary, AI translation, and language learning features for IINA",
  "author": {
    "name": "Polyscript",
    "email": "support@polyscript.app",
    "url": "https://polyscript.app"
  },
  "entry": "dist/index.js",
  "globalEntry": "dist/global.js",
  "permissions": [
    "show-osd",
    "show-alert",
    "video-overlay",
    "network-request",
    "file-system",
    "subtitle",
    "preferences"
  ],
  "sidebarTab": {
    "name": "Polyscript"
  },
  "subtitleProviders": [
    {
      "id": "polyscript-local-provider",
      "name": "Polyscript (Local Files)"
    }
  ],
  "allowedDomains": ["*", "polyscript.app", "api.polyscript.app", "translate.googleapis.com"],
  "preferenceDefaults": {
    "primaryLang": "en",
    "secondaryLang": "",
    "targetLang": "en",
    "fontSize": "large",
    "overlayFontSize": "large",
    "overlayBgColor": "0, 0, 0",
    "overlayBgOpacity": 0.85,
    "overlayTextColor": "#ffffff",
    "overlayPlacement": "auto",
    "overlayCustomOffset": 140,
    "overlayDock": "bottom",
    "showTransliteration": true,
    "segmentationEnabled": true,
    "ttsEnabled": true,
    "ttsOnWordClick": true,
    "ttsOnLineClick": true,
    "ttsRate": 190,
    "ttsVoice": "",
    "ttsAutoVoice": false,
    "ttsEngine": "say",
    "ttsNativeBaseUrl": "http://127.0.0.1:8123",
    "ttsNativeHelperPath": "",
    "ttsNativeAutoStart": true,
    "ttsPreferPersonal": true,
    "ttsNativeEngine": "nss",
    "ttsVoiceMap": "",
    "ttsDebug": false,
    "autoArrangeSubs": true,
    "primarySubPosition": "bottom",
    "secondarySubPosition": "bottom",
    "translationProvider": "google",
    "polyscriptToken": "",
    "polyscriptLoginEmail": "",
    "polyscriptBaseUrl": "https://polyscript.app",
    "llmModel": "gpt-4o-mini",
    "llmTemperature": 0.3,
    "llmMaxTokens": 2000,
    "llmMode": "translate",
    "llmMetaPrompt": "",
    "llmCustomPrompt": "",
    "llmCustomTarget": "",
    "sentenceMode": false,
    "sentenceAutoResume": false,
    "sentenceAutoResumeDelay": 2,
    "sentenceTtsOnPause": false,
    "psPresets": "",
    "psRecentLangs": "",
    "polyscriptEnabled": true,
    "autoLoadSubtitles": false,
    "autoPickSourceSubtitles": true,
    "ttsCloudFallback": true,
    "psTelemetryDeviceId": ""
  }
}
